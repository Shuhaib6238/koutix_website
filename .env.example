# Server
PORT=3000
NODE_ENV=development

# Security — CHANGE THIS in production!
SESSION_SECRET=your_super_secret_key_here_min_32_chars

# CORS
ALLOWED_ORIGIN=http://localhost:3000

# Database (when replacing mock data)
# DATABASE_URL=postgresql://user:pass@localhost:5432/koutix
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_KEY=your_service_key

# Email (for invitations)
# SENDGRID_API_KEY=SG.xxx
# FROM_EMAIL=noreply@koutix.io

# JWT (if switching to stateless auth)
# JWT_SECRET=your_jwt_secret
# JWT_EXPIRES_IN=7d
